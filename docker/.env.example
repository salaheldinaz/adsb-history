# Copy to .env and adjust as needed: cp .env.example .env
# All data lives under the repo's data/ folder; compose reads this file when you run from repo root with -f docker/docker-compose.yml (use docker/.env).

# --- Postgres (used by the postgres container only) ---
POSTGRES_USER=adsb
POSTGRES_PASSWORD=adsb
POSTGRES_DB=adsb

# --- API + data-loading: how they connect to the DB ---
# Use either (DB_* + local postgres) OR DATABASE_URL (external DB).
DB_HOST=postgres
DB_NAME=adsb
DB_USER=adsb
DB_PASS=adsb
DB_PORT=5432
# For external DB, set DATABASE_URL and run with -f docker-compose.external-db.yml:
# DATABASE_URL=postgresql://user:pass@host:5432/adsb

DISABLE_AUTH=1
QUERY_HISTORY_BACKUP_PATH=/data/query-history-backup.json
FIREBASE_SERVICE_ACCOUNT_KEY=/app/firebase-key.json

# --- Frontend build args (API URL as seen by the browser) ---
# Leave empty for Docker: frontend container proxies /api to api:5000 (same-origin).
# For local dev or external access set e.g. http://localhost:5000 or http://host:5000
VITE_API_BASE_URL=
VITE_DISABLE_AUTH=1

# --- Host ports (left side of host:container; container ports stay 5432, 5000, 80) ---
# POSTGRES_PORT=5432
# API_PORT=5000
# FRONTEND_PORT=8080
